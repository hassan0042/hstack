+/* Stock Monitor — palette per the validated dataviz reference instance.
+   Roles are defined once here; the chart JS reads them via CSS custom props. */
+
+* { margin: 0; padding: 0; box-sizing: border-box; }
+
+:root {
+  color-scheme: light;
+  --page: #f9f9f7;
+  --surface-1: #fcfcfb;
+  --text-primary: #0b0b0b;
+  --text-secondary: #52514e;
+  --text-muted: #898781;
+  --grid: #e1e0d9;
+  --baseline: #c3c2b7;
+  --border: rgba(11, 11, 11, 0.10);
+  --series-1: #2a78d6;
+  --up: #006300;
+  --down: #d03b3b;
+  --status-good: #0ca30c;
+  --status-warning: #fab219;
+  --status-serious: #ec835a;
+  --status-critical: #d03b3b;
+  --chip-good-bg: rgba(12, 163, 12, 0.12);
+  --chip-warn-bg: rgba(250, 178, 25, 0.16);
+  --chip-serious-bg: rgba(236, 131, 90, 0.16);
+  --chip-neutral-bg: rgba(11, 11, 11, 0.06);
+  --hover-wash: rgba(11, 11, 11, 0.04);
+}
+
+@media (prefers-color-scheme: dark) {
+  :root:where(:not([data-theme="light"])) {
+    color-scheme: dark;
+    --page: #0d0d0d;
+    --surface-1: #1a1a19;
+    --text-primary: #ffffff;
+    --text-secondary: #c3c2b7;
+    --text-muted: #898781;
+    --grid: #2c2c2a;
+    --baseline: #383835;
+    --border: rgba(255, 255, 255, 0.10);
+    --series-1: #3987e5;
+    --up: #0ca30c;
+    --down: #e66767;
+    --chip-neutral-bg: rgba(255, 255, 255, 0.08);
+    --hover-wash: rgba(255, 255, 255, 0.05);
+  }
+}
+:root[data-theme="dark"] {
+  color-scheme: dark;
+  --page: #0d0d0d;
+  --surface-1: #1a1a19;
+  --text-primary: #ffffff;
+  --text-secondary: #c3c2b7;
+  --text-muted: #898781;
+  --grid: #2c2c2a;
+  --baseline: #383835;
+  --border: rgba(255, 255, 255, 0.10);
+  --series-1: #3987e5;
+  --up: #0ca30c;
+  --down: #e66767;
+  --chip-neutral-bg: rgba(255, 255, 255, 0.08);
+  --hover-wash: rgba(255, 255, 255, 0.05);
+}
+
+body {
+  font-family: system-ui, -apple-system, "Segoe UI", sans-serif;
+  background: var(--page);
+  color: var(--text-primary);
+  min-height: 100vh;
+  display: flex;
+  flex-direction: column;
+}
+
+/* ── Top bar ─────────────────────────────────────────── */
+.topbar {
+  display: flex;
+  align-items: center;
+  gap: 20px;
+  padding: 12px 24px;
+  border-bottom: 1px solid var(--border);
+  background: var(--surface-1);
+  flex-wrap: wrap;
+}
+.brand { display: flex; align-items: center; gap: 8px; }
+.brand h1 { font-size: 17px; font-weight: 650; }
+.brand-mark { font-size: 18px; }
+
+.tabs { display: flex; gap: 4px; background: var(--hover-wash); border-radius: 10px; padding: 3px; }
+.tab {
+  border: none;
+  background: transparent;
+  color: var(--text-secondary);
+  font: inherit;
+  font-size: 13.5px;
+  font-weight: 550;
+  padding: 7px 16px;
+  border-radius: 8px;
+  cursor: pointer;
+}
+.tab:hover { color: var(--text-primary); }
+.tab.active {
+  background: var(--surface-1);
+  color: var(--text-primary);
+  box-shadow: 0 1px 2px rgba(0, 0, 0, 0.12);
+}
+
+.topbar-right { margin-left: auto; display: flex; align-items: center; gap: 10px; }
+.icon-btn {
+  border: 1px solid var(--border);
+  background: var(--surface-1);
+  color: var(--text-secondary);
+  font: inherit;
+  font-size: 12.5px;
+  padding: 6px 12px;
+  border-radius: 8px;
+  cursor: pointer;
+}
+.icon-btn:hover { color: var(--text-primary); background: var(--hover-wash); }
+
+.source-badge {
+  display: inline-flex;
+  align-items: center;
+  gap: 6px;
+  font-size: 12px;
+  color: var(--text-secondary);
+  border: 1px solid var(--border);
+  padding: 5px 10px;
+  border-radius: 999px;
+}
+.source-badge .dot { width: 8px; height: 8px; border-radius: 50%; }
+
+/* ── Layout ──────────────────────────────────────────── */
+main { flex: 1; padding: 20px 24px; max-width: 1440px; width: 100%; margin: 0 auto; }
+
+.kpi-row {
+  display: grid;
+  grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
+  gap: 14px;
+  margin-bottom: 16px;
+}
+
+.main-grid {
+  display: grid;
+  grid-template-columns: minmax(0, 2.2fr) minmax(280px, 1fr);
+  gap: 16px;
+  align-items: start;
+}
+@media (max-width: 980px) {
+  .main-grid { grid-template-columns: 1fr; }
+}
+
+.left-col, .right-col { display: flex; flex-direction: column; gap: 16px; min-width: 0; }
+
+.panel {
+  background: var(--surface-1);
+  border: 1px solid var(--border);
+  border-radius: 12px;
+  padding: 16px 18px;
+}
+.panel-head { display: flex; align-items: baseline; gap: 10px; flex-wrap: wrap; margin-bottom: 10px; }
+.panel-head h2 { font-size: 14.5px; font-weight: 650; }
+.panel-sub { font-size: 12px; color: var(--text-muted); }
+
+/* ── Stat tiles ──────────────────────────────────────── */
+.stat-tile {
+  background: var(--surface-1);
+  border: 1px solid var(--border);
+  border-radius: 12px;
+  padding: 14px 16px;
+  display: flex;
+  flex-direction: column;
+  gap: 4px;
+}
+.stat-label { font-size: 12.5px; color: var(--text-secondary); }
+.stat-value { font-size: 26px; font-weight: 600; line-height: 1.15; }
+.stat-value .unit { font-size: 15px; font-weight: 500; color: var(--text-secondary); }
+.stat-delta { font-size: 12.5px; font-weight: 550; }
+.stat-delta.up { color: var(--up); }
+.stat-delta.down { color: var(--down); }
+.stat-delta .vs { color: var(--text-muted); font-weight: 400; }
+.stat-spark { margin-top: 6px; }
+
+/* ── Table ───────────────────────────────────────────── */
+.table-wrap { overflow-x: auto; }
+#stock-table { width: 100%; border-collapse: collapse; font-size: 13px; }
+#stock-table th {
+  text-align: right;
+  font-size: 11.5px;
+  font-weight: 550;
+  color: var(--text-muted);
+  padding: 6px 10px;
+  border-bottom: 1px solid var(--grid);
+  cursor: pointer;
+  user-select: none;
+  white-space: nowrap;
+}
+#stock-table th:first-child { text-align: left; }
+#stock-table th:hover { color: var(--text-primary); }
+#stock-table th .arrow { font-size: 9px; }
+#stock-table td {
+  padding: 8px 10px;
+  border-bottom: 1px solid var(--grid);
+  text-align: right;
+  font-variant-numeric: tabular-nums;
+  white-space: nowrap;
+}
+#stock-table td:first-child { text-align: left; }
+#stock-table tbody tr { cursor: pointer; }
+#stock-table tbody tr:hover { background: var(--hover-wash); }
+#stock-table tbody tr.selected { background: color-mix(in srgb, var(--series-1) 8%, transparent); }
+#stock-table tbody tr:last-child td { border-bottom: none; }
+
+.sym { font-weight: 650; }
+.sym-name { display: block; font-size: 11px; font-weight: 400; color: var(--text-muted); }
+td.up { color: var(--up); }
+td.down { color: var(--down); }
+
+.chip {
+  display: inline-flex;
+  align-items: center;
+  gap: 5px;
+  font-size: 11.5px;
+  font-weight: 550;
+  color: var(--text-primary);
+  padding: 3px 9px;
+  border-radius: 999px;
+  white-space: nowrap;
+}
+.chip .chip-ico { font-size: 10px; }
+.chip-buy { background: var(--chip-good-bg); }
+.chip-buy .chip-ico { color: var(--status-good); }
+.chip-acc { background: var(--chip-warn-bg); }
+.chip-acc .chip-ico { color: var(--status-warning); }
+.chip-hold { background: var(--chip-neutral-bg); }
+.chip-hold .chip-ico { color: var(--text-muted); }
+.chip-weak { background: var(--chip-serious-bg); }
+.chip-weak .chip-ico { color: var(--status-serious); }
+
+.score-cell { display: inline-flex; align-items: center; gap: 8px; justify-content: flex-end; }
+.score-meter {
+  width: 52px;
+  height: 6px;
+  border-radius: 3px;
+  background: color-mix(in srgb, var(--series-1) 18%, transparent);
+  overflow: hidden;
+}
+.score-meter > i { display: block; height: 100%; background: var(--series-1); border-radius: 3px; }
+
+/* ── Suggestions ─────────────────────────────────────── */
+.sugg {
+  padding: 12px 0;
+  border-bottom: 1px solid var(--grid);
+}
+.sugg:first-child { padding-top: 2px; }
+.sugg:last-child { border-bottom: none; padding-bottom: 2px; }
+.sugg-head { display: flex; align-items: center; gap: 8px; margin-bottom: 4px; }
+.sugg-rank {
+  font-size: 11px;
+  font-weight: 650;
+  color: var(--text-muted);
+  border: 1px solid var(--border);
+  border-radius: 6px;
+  width: 20px; height: 20px;
+  display: inline-flex; align-items: center; justify-content: center;
+}
+.sugg-sym { font-weight: 650; font-size: 13.5px; }
+.sugg-name { font-size: 12px; color: var(--text-muted); }
+.sugg-score { margin-left: auto; font-size: 12px; color: var(--text-secondary); font-variant-numeric: tabular-nums; }
+.sugg ul { margin: 4px 0 0 0; padding-left: 18px; }
+.sugg li { font-size: 12.3px; color: var(--text-secondary); line-height: 1.45; margin-bottom: 2px; }
+.caution-panel .sugg-head { margin-bottom: 2px; }
+.empty-note { font-size: 12.5px; color: var(--text-muted); padding: 6px 0; }
+
+.disclaimer {
+  font-size: 11.8px;
+  line-height: 1.5;
+  color: var(--text-muted);
+  padding: 2px 4px;
+}
+.disclaimer strong { color: var(--text-secondary); }
+
+/* ── Detail chart ────────────────────────────────────── */
+.detail-chart { position: relative; }
+.detail-chart svg { display: block; width: 100%; height: auto; }
+
+.tooltip {
+  position: fixed;
+  z-index: 10;
+  pointer-events: none;
+  background: var(--surface-1);
+  border: 1px solid var(--border);
+  border-radius: 8px;
+  box-shadow: 0 4px 14px rgba(0, 0, 0, 0.14);
+  padding: 8px 10px;
+  font-size: 12px;
+  color: var(--text-secondary);
+  min-width: 130px;
+}
+.tooltip .tt-date { color: var(--text-muted); font-size: 11px; margin-bottom: 2px; }
+.tooltip .tt-price { color: var(--text-primary); font-weight: 650; font-size: 14px; font-variant-numeric: tabular-nums; }
+.tooltip .tt-delta { font-variant-numeric: tabular-nums; }
+.tooltip .tt-delta.up { color: var(--up); }
+.tooltip .tt-delta.down { color: var(--down); }
+
+/* ── Footer ──────────────────────────────────────────── */
+.footer {
+  display: flex;
+  justify-content: space-between;
+  gap: 16px;
+  flex-wrap: wrap;
+  padding: 12px 24px;
+  font-size: 11.5px;
+  color: var(--text-muted);
+  border-top: 1px solid var(--border);
+}
+
+.loading { padding: 40px; text-align: center; color: var(--text-muted); font-size: 13px; }
diff --git a/stock-monitor/server.ts b/stock-monitor/server.ts
